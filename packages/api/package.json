{
  "name": "@sendwyrd/api",
  "version": "0.1.0",
  "private": true,
  "description": "SendWyrd API — Hono on Cloudflare Workers; mounts at sendwyrd.com/api/*",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "echo 'wrangler builds at deploy time' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests yet' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@sendwyrd/core": "workspace:*",
    "drizzle-orm": "^0.38.2",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
