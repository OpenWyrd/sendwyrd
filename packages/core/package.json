{
  "name": "@sendwyrd/core",
  "version": "0.1.0",
  "private": false,
  "description": "SendWyrd shared core: crypto envelope, HD derivation, URL parsing, wire types. Reference TypeScript implementation of the SendWyrd protocol.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://sendwyrd.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openwyrd/sendwyrd.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/openwyrd/sendwyrd/issues"
  },
  "keywords": [
    "sendwyrd",
    "capability-url",
    "ephemeral",
    "encrypted-messaging",
    "secp256k1",
    "schnorr",
    "bip32",
    "bip39"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./crypto": {
      "types": "./dist/envelope.d.ts",
      "import": "./dist/envelope.js",
      "default": "./dist/envelope.js"
    },
    "./hd": {
      "types": "./dist/hd.d.ts",
      "import": "./dist/hd.js",
      "default": "./dist/hd.js"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.js",
      "default": "./dist/url.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@noble/curves": "^1.7.0",
    "@noble/hashes": "^1.6.1",
    "@scure/bip32": "^1.6.0",
    "@scure/bip39": "^1.5.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
