{
  "name": "@sendwyrd/core",
  "version": "0.2.0",
  "private": false,
  "description": "DEPRECATED — re-export shim for @openwyrd/mop. Use @openwyrd/mop directly. This package will be deprecated 60 days after v0.2.0 publish.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://openwyrd.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openwyrd/sendwyrd.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/openwyrd/mop-js/issues"
  },
  "keywords": [
    "deprecated",
    "shim",
    "openwyrd",
    "mop"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "echo 'Tests live in @openwyrd/mop; this is a re-export shim.'",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@openwyrd/mop": "0.2.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
