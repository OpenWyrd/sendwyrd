{
  "name": "@sendwyrd/mcp",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Model Context Protocol server for SendWyrd. Exposes compose / view / burn / reply / attest as agent-callable tools over stdio.",
  "license": "MIT",
  "homepage": "https://sendwyrd.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeltaClimbs/sendwyrd.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/DeltaClimbs/sendwyrd/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sendwyrd",
    "claude",
    "agent",
    "ephemeral",
    "capability-url",
    "encrypted-messaging"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sendwyrd-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --legal-comments=external && chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@sendwyrd/core": "workspace:*",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.23.8"
  }
}
