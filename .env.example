# SendWyrd environment — copy to .env.local (gitignored) and fill in real values.
#
# Production secrets for the Cloudflare Worker are set via:
#   cd packages/api && wrangler secret put DATABASE_URL
# (do NOT put production secrets in this file or .env.local).

# Neon Postgres connection string (development pooler URL).
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Cloudflare account ID (`wrangler whoami` reports this).
CLOUDFLARE_ACCOUNT_ID=

# Public web origin (for CORS allowlist on the API).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8787
NEXT_PUBLIC_WEB_BASE_URL=http://127.0.0.1:3000
